{
  "name": "ppt-translate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "start": "node server/index.js",
    "test": "vitest run --config vitest.config.js"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@vitejs/plugin-react": "^5.1.1",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.3.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "pdfjs-dist": "^5.4.394",
    "pdfkit": "^0.18.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tesseract.js": "^6.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "vite": "^8.0.14",
    "vitest": "^4.0.15"
  }
}
