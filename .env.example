PORT=4000
PUBLIC_BASE_URL=http://localhost:4000

# Translation providers. These can also be saved from the web UI after login.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-1-6-251015
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
PREFERRED_TRANSLATION_PROVIDER=auto
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Dedicated OCR / formula recognition. Recommended for scanned PDFs and math-heavy docs.
# These can also be saved from the web UI after login.
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# Local OCR fallback for PPT images. Uses tesseract.js and may be slower.
ENABLE_LOCAL_OCR=true
TESSERACT_LANG=eng+chi_sim
